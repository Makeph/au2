# AU2 — Environment variables template
# Copy to .env and fill in values. NEVER commit .env to git.

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Binance (paper mode — testnet or unused) ──────────────────────────────────
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_FAPI_WS=wss://fstream.binance.com/stream

# ── Bot ───────────────────────────────────────────────────────────────────────
BOT_SYMBOL=BTCUSDT
START_EQUITY=10000
LOG_LEVEL=INFO

# ── Safety — DO NOT CHANGE to true without Telegram APPROVE ENABLE_LIVE_TRADING
LIVE_ENABLED=false
LIVE_MODE=false

# ── Claude Code (for /gpatch Telegram command) ────────────────────────────────
ANTHROPIC_API_KEY=
GOAT_CLAUDE_WORKDIR=/root/bot_au2qwen
