# Data / DB files — large, not versionned
data/validated/*.db
data/live/*.jsonl
data/live/*.json
data/live/*.log
*.db

# Python cache
__pycache__/
*.pyc
*.pyo
.mypy_cache/

# Models / binaries
models/*.pkl
models/*.joblib
*.pkl
*.joblib

# Env secrets — never commit real credentials
.env
.env.local
.env.production
*.key
*.pem
secrets/
reports/private/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Test artifacts
.pytest_cache/
htmlcov/
.coverage

# Logs
logs/
*.log
